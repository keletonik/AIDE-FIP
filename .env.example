# AIDE-FIP environment

# Public knowledge base URL — link-out target for standards / panel docs.
NEXT_PUBLIC_KB_URL=https://keletonik.github.io/knowledge-bage

# SQLite file location. Defaults to ./data/aide.db relative to the project root.
AIDE_DB_PATH=./data/aide.db

# Auditor / debugger gate. Set to a long random string in Replit Secrets.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_KEY=<set-in-replit-secrets>

# Set to "1" to capture every request in the debug ring buffer (dev only).
AIDE_DEBUG_VERBOSE=0

# Bootstrap admin user on first build/seed. Set in Replit Secrets, NEVER
# commit real values to this file. Subsequent builds are no-op (won't
# overwrite an existing user). Rotate the password after first login with
# `npm run user:create <username> '<new-password>' --admin`.
AIDE_BOOTSTRAP_USERNAME=<set-in-replit-secrets>
AIDE_BOOTSTRAP_PASSWORD=<set-in-replit-secrets>
AIDE_BOOTSTRAP_NAME=<display-name>
# AIDE_BOOTSTRAP_EMAIL=admin@example.com

# Set to "1" only when running behind a trusted proxy that strips client-set
# X-Forwarded-For. On Replit Reservedvm leave unset.
TRUSTED_PROXY=0
