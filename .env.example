# AIDE-FIP environment

# Public knowledge base URL — link-out target for standards / panel docs.
# Override on Replit secrets when knowledge-bage moves off GitHub Pages.
NEXT_PUBLIC_KB_URL=https://keletonik.github.io/knowledge-bage

# SQLite file location. Defaults to ./data/aide.db relative to the project root.
AIDE_DB_PATH=./data/aide.db

# Auditor / debugger gate. Set to a long random string and provide as
# ?key=... in the admin URL, or set a session cookie via the login page.
ADMIN_KEY=changeme-rotate-on-deploy

# Set to "1" to capture every request in the debug ring buffer (dev only).
AIDE_DEBUG_VERBOSE=0
