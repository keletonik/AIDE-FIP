run = "npm run dev"
entrypoint = "app/page.tsx"
modules = ["nodejs-20", "web"]
hidden = [".next", "node_modules", "data/aide.db", "data/aide.db-journal", "data/aide.db-shm", "data/aide.db-wal", "data/uploads"]

[nix]
channel = "stable-24_05"

# Deployment target.
#
# AIDE-FIP stores everything on local disk: SQLite at ./data/aide.db plus
# uploaded photos under ./data/uploads/. That's deliberate — no external
# infra to provision on Replit — but it forces a deployment-target choice.
#
#   reservedvm   — single-instance VM with a persistent disk. Workflow
#                  data (sites, defects, photos, services) survives
#                  redeploys. THIS IS THE RIGHT CHOICE for AIDE-FIP as
#                  currently architected.
#
#   cloudrun     — autoscale, scales to zero, but the writable filesystem
#                  is ephemeral. Every redeploy = empty workflow data.
#                  Only reference data (which ships baked into the build
#                  via npm run db:seed) is there. Do not use for AIDE-FIP
#                  unless you've migrated to Postgres + object storage first.
#
# To swap, change deploymentTarget below and re-deploy.
[deployment]
deploymentTarget = "reservedvm"
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]
ignorePorts = false

[env]
NEXT_TELEMETRY_DISABLED = "1"
NODE_ENV = "development"
PORT = "3000"

[[ports]]
localPort = 3000
externalPort = 80

[languages]

[languages.typescript]
pattern = "**/{*.ts,*.tsx}"

[languages.typescript.languageServer]
start = "typescript-language-server --stdio"
